const defaultLayout = {
  global: { tabEnableClose: false },
  layout: {
    type: 'row',
    children: [
      {
        type: 'row',
        weight: 50,
        children: [
          {{#each route.tiles}}
          {{#ifEquals @index 0}}
          { type: 'tabset', weight: 50, children: [{ type: 'tab', name: '{{this.title}}', component: '{{camelCase this.componentName}}' }] },
          {{/ifEquals}}
          {{#ifEquals @index 2}}
          { type: 'tabset', weight: 50, children: [{ type: 'tab', name: '{{this.title}}', component: '{{camelCase this.componentName}}' }] },
          {{/ifEquals}}
          {{/each}}
        ],
      },
      {
        type: 'row',
        weight: 50,
        children: [
          {{#each route.tiles}}
          {{#ifEquals @index 1}}
          { type: 'tabset', weight: 50, children: [{ type: 'tab', name: '{{this.title}}', component: '{{camelCase this.componentName}}' }] },
          {{/ifEquals}}
          {{#ifEquals @index 3}}
          { type: 'tabset', weight: 50, children: [{ type: 'tab', name: '{{this.title}}', component: '{{camelCase this.componentName}}' }] },
          {{/ifEquals}}
          {{/each}}
        ],
      },
    ],
  },
};
